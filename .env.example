# Strapi CMS
NUXT_PUBLIC_STRAPI_URL=https://striking-bear-e5a15ddc94.strapiapp.com
NUXT_PUBLIC_MEDIA_URL=https://striking-bear-e5a15ddc94.media.strapiapp.com

# Preview Mode (must match Strapi config/admin.ts previewSecret)
PREVIEW_SECRET=your-secret-key-here

# Webhook Revalidation (set in Strapi webhook header x-webhook-secret)
STRAPI_WEBHOOK_SECRET=your-webhook-secret-here

# Site Mode (optional: 'store' or 'ads')
NUXT_PUBLIC_SITE_MODE=store

# Google Services
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-key
NUXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-map-id

# Analytics & Tracking
NUXT_PUBLIC_GTM_ENABLED=true
NUXT_PUBLIC_GTM_SERVER_URL=https://engine.myhealthandbeauty.com
NUXT_PUBLIC_GTM_CONTAINER_URL=https://engine.myhealthandbeauty.com/lrfdq8xa.js

# Sentry Error Tracking
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=my-health-and-beauty
SENTRY_PROJECT=myhb-store
